# Application
APP_NAME=Assistant
APP_HOST=0.0.0.0
APP_PORT=8080
DEBUG=True
LOG_LEVEL=DEBUG
DOMAIN=yourdomain.com

# Database (PostgreSQL)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=tutor_assistant
DB_USER=postgres
DB_PASSWORD=your-db-password

# Compose-level Postgres config (used by postgres container)
POSTGRES_DB=tutor_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
PGDATA=/var/lib/postgresql/data/pgdata

# LLM (OpenRouter-compatible or any OpenAI-compatible endpoint)
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=openai/gpt-4o
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.8
LLM_MAX_CONCURRENT_CALLS=8
LLM_TIMEOUT=900

# Only needed for providers that scope API keys to a project/folder, e.g. Yandex Cloud:
#   LLM_API_BASE=https://ai.api.cloud.yandex.net/v1
#   LLM_MODEL=gpt://<folder_id>/yandexgpt/latest
#   LLM_PROJECT_ID=<folder_id>
LLM_PROJECT_ID=

# Cheap LLM — for extraction and chat name generation
# If not set, falls back to LLM_API_BASE / LLM_API_KEY
LLM_CHEAP_API_BASE=
LLM_CHEAP_API_KEY=
LLM_CHEAP_MODEL=openai/gpt-4o-mini

# Image generation
IMAGE_GEN_ENABLED=True
IMAGE_GEN_API_BASE=https://openrouter.ai/api/v1
IMAGE_GEN_API_KEY=your-image-gen-api-key
IMAGE_GEN_MODEL=openai/dall-e-3

# Stock photo search (Pexels)
STOCK_PHOTO_ENABLED=True
PEXELS_API_KEY=your-pexels-api-key

# OCR (ocr.space API)
OCR_API_KEY=your-ocr-api-key
OCR_LANGUAGE=auto

# S3-compatible object storage (MinIO / Cloudflare R2 / AWS S3)
S3_BUCKET=tutor
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=your-minio-access-key
S3_SECRET_KEY=your-minio-secret-key
S3_REGION=us-east-1
S3_KEY_PREFIX=

# Authentication
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
REGISTRATION_ENABLED=False

# Admin account (seeded on first run)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Cleanup task
ENABLE_CLEANUP_TASK=True
CLEANUP_DELETED_AFTER_DAYS=30
CLEANUP_INTERVAL_HOURS=24

# Langfuse (optional — set LANGFUSE_ENABLED=True to activate)
LANGFUSE_ENABLED=False
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key

# Traefik (production only)
ACME_EMAIL=your-email@example.com
# Generate with: echo $(htpasswd -nB user) | sed -e s/\\$/\\$\\$/g
TRAEFIK_BASIC_AUTH_USERS=user:$$2a$$14$$...
